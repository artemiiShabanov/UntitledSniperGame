; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Sniper"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.4", "Forward Plus")
config/icon="res://icon.svg"

[audio]

default_bus_layout="res://default_bus_layout.tres"

[autoload]

SaveManager="*res://scripts/systems/save_manager.gd"
RunManager="*res://scripts/systems/run_manager.gd"
ModRegistry="*res://scripts/data/mod_registry.gd"
SkillRegistry="*res://scripts/data/skill_registry.gd"
OpportunityRegistry="*res://scripts/data/opportunity_registry.gd"
ArmyUpgradeRegistry="*res://scripts/data/army_upgrade_registry.gd"
SettingsManager="*res://scripts/ui/settings_manager.gd"
PauseMenu="*res://scenes/ui/pause_menu.tscn"
PaletteManager="*res://scripts/systems/palette_manager.gd"
PaletteTheme="*res://scripts/ui/palette_theme.gd"
LoadingScreen="*res://scenes/ui/loading_screen.tscn"
FilmGrainOverlay="*res://scenes/ui/film_grain_overlay.tscn"
VFXFactory="*res://scripts/systems/vfx_factory.gd"
AudioManager="*res://scripts/systems/audio_manager.gd"
DevBootstrap="*res://scripts/dev/dev_bootstrap.gd"

[display]

window/size/mode=2

[gui]

theme/custom_font="res://assets/fonts/JetBrainsMono-Regular.ttf"
theme/default_font_size=16

